# ============================================================================
# .env.example — every secret/config the project will need, with WHERE it lives.
# Copy to .env for local work (gitignored). NEVER commit real values.
# Real secrets live ONLY in Supabase / Vercel / GitHub-Actions env config.
# ============================================================================

# ---- Local database tooling (db/ scripts) ----
# Optional override; when unset the scripts boot an ephemeral embedded Postgres.
# The scripts REFUSE any *.supabase.co host (prod guard) — local/CI only.
DATABASE_URL=

# ---- Supabase DEV project (Phase 0 human step — never the prod ref oafovcrxdjoyaxsytyjg) ----
SUPABASE_DEV_URL=
SUPABASE_DEV_PUBLISHABLE_KEY=
# service-role key: NEVER in this file, NEVER in the repo, NEVER in a client.
# It exists only inside Supabase Edge Function secrets (set via dashboard/CLI).

# ---- Observability (Phase 0 scaffold; account created later) ----
SENTRY_DSN=
VITE_SENTRY_DSN=

# ---- Stripe (Phase 3.5 — TEST MODE keys first; live mode is a STOP-approval item) ----
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET=

# ---- AI providers (Phase 5+; server-side only, via the provider-agnostic adapter) ----
AI_PROVIDER=            # e.g. 'anthropic' — adapter is config-chosen
ANTHROPIC_API_KEY=
AI_DAILY_BUDGET_USD_PER_CHILD=
AI_DAILY_BUDGET_USD_PER_ACCOUNT=

# ---- Email notifications (Phase 8) ----
EMAIL_PROVIDER_API_KEY=
